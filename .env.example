# ─── Image Generation API Configuration ───────────────────────────────
# For the static site, copy these values into js/config.js
#
# Primary API (Pollinations AI — recommended, no key required)
# https://image.pollinations.ai/p/{prompt}?width=1024&height=1024
NEXT_PUBLIC_API_BASE_URL=https://image.pollinations.ai/p/
#
# Fallback API (img.sed.me — direct Stable Diffusion proxy)
# https://img.sed.me/?prompt={prompt}
NEXT_PUBLIC_FALLBACK_API_BASE_URL=https://img.sed.me/
#
# Ultimate fallback (Unsplash Source — real stock photos)
# https://source.unsplash.com/featured/1024x1024/?{query}
NEXT_PUBLIC_ULTIMATE_FALLBACK_API_BASE_URL=https://source.unsplash.com/featured/
#
# Default image dimensions
NEXT_PUBLIC_DEFAULT_WIDTH=1024
NEXT_PUBLIC_DEFAULT_HEIGHT=1024
